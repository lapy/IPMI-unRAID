<div class="ipmi-shell ipmi-tool-shell">
    <section class="ipmi-page-hero ipmi-page-hero--no-strip">
        <div class="ipmi-page-hero__main">
            <div class="ipmi-page-hero__eyebrow">IPMI</div>
            <h1>Event Log</h1>
            <p>Search, filter, and triage current SEL-derived events. Archive mode keeps deleted entries on flash storage for later review.</p>
        </div>
        <aside class="ipmi-page-hero__aside" aria-label="Archive option">
            <div class="ipmi-hero-stat">
                <div class="ipmi-hero-stat__label">Archive</div>
                <div class="ipmi-switch-meta">
                    <span class="ipmi-switch-label">Deleted events</span>
                    <span id="arch-switch" class="status"><input type="checkbox" id="event-arch" aria-label="Archive deleted events to flash"></span>
                </div>
            </div>
        </aside>
    </section>

    <div class="ipmi-table-shell">
        <table class="tablesorter shift hover-highlight events" id="tblEvent">
            <thead>
                <tr>
                    <th scope="col" class="sorter-false filter-false"> Status </th>
                    <th scope="col" class="network sorter-ipv4Address filter-ip" data-placeholder="by IP Address"> IP Address </th>
                    <th scope="col" class="filter-false"> Event ID </th>
                    <th scope="col" class="filter-time" data-placeholder="by timestamp"> Timestamp </th>
                    <th scope="col" class="filter-name" data-placeholder="Search..."> Sensor Name </th>
                    <th scope="col" class="filter-type" data-placeholder="by type"> Sensor Type </th>
                    <th scope="col" class="filter-desc" data-placeholder="Search..."> Description </th>
                    <th scope="col" class="filter-false sorter-false"><button type="button" class="ipmi-table-action" id="allEvents" title="Clear all events from this view"><i class="fa fa-trash" aria-hidden="true"></i> Clear all</button></th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

    <div id="pager" class="pager">
        <form>
            <a class="first"><i class="fa fa-step-backward"></i></a>
            <a class="prev"><i class="fa fa-backward"></i></a>
            <span class="pagedisplay"></span>
            <a class="next"><i class="fa fa-forward"></i></a>
            <a class="last"><i class="fa fa-step-forward"></i></a>
            <select class="pagesize">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="15">15</option>
                <option value="20">20</option>
                <option value="all">All</option>
            </select>
            <a title="reset filters" class="reset-events"><i class="fa fa-undo"></i></a>
