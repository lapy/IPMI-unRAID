window.IPMI_CSRF_TOKEN = '<?=htmlspecialchars($var['csrf_token']);?>';
</script>
<script src="<?=autov('/plugins/ipmi/js/ipmi-api.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/ipmi-monitor.js');?>"></script>
<script>
var ipmiDisplayUnitF = ('<?=htmlspecialchars($display['unit']);?>' === 'F');
var ipmiDashFetchBusy = false;

$(function(){
    $('#db-box1')
    .append('<tbody id="tblIPMIDash" class="sortable ui-sortable-handle"><tr><td></td><td colspan="3" class="next"><i class="icon-notifications"></i><div class="section"><strong>IPMI</strong><div class="ipmi-dashboard-reading">Live sensor summary</div><span id="ipmi-temp"></span></div><i class="fa fa-fw chevron fa-chevron-up" id="ipmi_view" onclick="toggleChevron(&quot;ipmi_view&quot;,0)"></i><a href="/Settings/IPMI/" title="Go to IPMI settings"><i class="fa fa-fw fa-cog chevron"></i></a></td><td></td></tr><tr class="ipmi_view" style="display: none;"><td></td><td>Status</td><td>Sensor</td><td>Reading</td><td></td></tr></tbody>');

    sensorArray(false);
    IpmiMonitor.startIntervalWhenVisible(20000, function() {
        sensorArray(true);
    });

});

/* load ipmi sensor table */
function sensorArray(Refresh){
    if (ipmiDashFetchBusy)
        return;
    ipmiDashFetchBusy = true;
    ipmiPost('/plugins/ipmi/include/ipmi_helpers.php', {action:'ipmidash'}, function(data) {
        ipmiDashFetchBusy = false;
        var unitF = ipmiDisplayUnitF;
        $.each(data.Sensors, function (i, sensor) {
            var rm = IpmiMonitor.readingMarkup(sensor, unitF);
            if(Refresh) {
                $('#'+i+' td.reading').html(rm);
            } else {
            $('#tblIPMIDash')
            .append("<tr class='ipmi_view' style='display: none;' id='"+i+"'><td></td>"+
            '<td title="'+sensor.State+'"><i class="fa fa-circle orb '+ data.State[sensor.State] +'-orb middle"></td>'+
            '<td>'+sensor.Name+'</td>'+
            '<td class="reading">'+ rm + '</td><td></td>'+
            '</tr>');
            }
        });
        toggleView('ipmi_view',true);
    }, function() {
        ipmiDashFetchBusy = false;
    });
}

</script>
