window.IPMI_CSRF_TOKEN = '<?=htmlspecialchars($var['csrf_token']);?>';
</script>
<script src="<?=autov('/plugins/ipmi/js/ipmi-api.js');?>"></script>

<script>
$(function(){
    //event archive switch set cookie and toggle archive setting
    function ipmiSetHostArchiveTabVisible(show) {
        if (typeof ipmiToggleMainTabControls === 'function')
            ipmiToggleMainTabControls(/archived events/i, show);
    }

    $('#event-arch').switchButton({
        labels_placement: 'left',
        on_label: 'Archive On',
        off_label: 'Archive Off',
        checked: ($.cookie('ipmi_event_archive') == 1)
    })
    .change(function () {
        $.cookie('ipmi_event_archive', $('#event-arch')[0].checked ? 1 : 0, { expires: 3650 });
        ipmiSetHostArchiveTabVisible($('#event-arch')[0].checked);
    });

    ipmiSetHostArchiveTabVisible($.cookie('ipmi_event_archive') == 1);

    $('#tblEvent').tablesorter({
        sortList: [[2,1]],
        sortReset: true,
        sortRestart : true,
        sortInitialOrder: 'asc',
        widgets: ['saveSort', 'filter', 'stickyHeaders'],
        widgetOptions: {
            stickyHeaders_offset: ($('#header').css("position") === "fixed") ? '90' : '0',
            stickyHeaders_attachTo: null,
            stickyHeaders_filteredToTop: true,
            filter_hideEmpty : true,
            filter_liveSearch : true,
            filter_saveFilters : true,
            filter_reset : '.reset-events',
            filter_functions: {
                '.filter-ip' : true,
                '.filter-type' : true,
                '.filter-time' : {
                    '3 days'		: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 259200000); }, //3*24*60*60 3 days
                    '1 week'		: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 604800000); }, //7*24*60*60 1 week
                    '2 weeks'	: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 1209600000); }, //14*24*60*60 2 weeks
                    '1 month'	: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 2592000000); }, //30*24*60*60 1 month
                    '6 months'	: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 15724800000); }, //26*7*24*60*60 6 months
                    '1 year'		: function(e, n, f, i, $r, c, data) {
                        return ($.now() - n <= 31449600000); } //52*7*24*60*60 1 year
                }
            }
        }
    })
    .tablesorterPager({
        container: $('#pager'),
        fixedHeight: false,
        size: 20
    });

    // add network class to ip address filter row cells
    $('#tblEvent tr.tablesorter-filter-row').children('td:nth-child(2)').addClass('network');

    $(document).on('click', '#tblEvent .ipmi-row-delete', function() {
        Delete($(this).data('event-id'));
    });
    $('#allEvents').on('click', function() {
        Delete(0);
    });

    eventArray();
});

var ipmiEventsLoadBusy = false;

function ipmiRefreshArchiveTableIfPresent() {
    if ($('#tblArchive').length && typeof window.archiveArray === 'function')
        window.archiveArray();
}

/* load ipmi event table */
function eventArray(){
    if (ipmiEventsLoadBusy)
        return;
    ipmiEventsLoadBusy = true;
    $('#tblEvent tbody').html("<tr><td colspan='8'><br><i class='fa fa-spinner fa-spin icon'></i><em>Loading events…</em></td></tr>");
    ipmiPost('/plugins/ipmi/include/ipmi_helpers.php', {action:'ipmievents'}, function(data) {
        ipmiEventsLoadBusy = false;
        $('#tblEvent tbody').empty();
        var rows = [];
        $.each(data.Events, function (i, event) {
            var Host = (typeof event.IP === 'undefined') ? '' : event.IP;
            rows.push('<tr id="'+i+'">'+
            '<td title="'+ event.State +'"><i class="fa fa-circle orb '+ data.State[event.State] +'-orb middle"></td>'+
            '<td class="network">'+ Host +'</td>'+
            '<td>'+ event.ID    +'</td>'+
            '<td>'+ event.Date  +'</td>'+
            '<td>'+ event.Name  +'</td>'+
            '<td>'+ event.Type  +'</td>'+
            '<td>'+ event.Event +'</td>'+
            '<td><button type="button" class="ipmi-table-action ipmi-row-delete" data-event-id="'+i+'" title="Delete event"><i class="fa fa-trash" aria-hidden="true"></i></button></td>'+
            '</tr>');
        });
        $('#tblEvent tbody').append(rows.join(''));

        if(data.Network)
            $('.network').show();
        else
            $('.network').hide();

        // restore filters and update table for tablesorter
        var lastSearch = $('#tblEvent')[0].config.lastSearch;
        $('#tblEvent').trigger('update');
        $('#tblEvent').trigger('search', [lastSearch]);
    }, function() {
        ipmiEventsLoadBusy = false;
        $('#tblEvent tbody').html("<tr><td colspan='8'><em>Could not load events.</em></td></tr>");
    });
}

/* delete event function */
function Delete(ID) {
    var EventDelete = '/plugins/ipmi/include/ipmi_event_delete.php';
    var Archive = $.cookie('ipmi_event_archive');
    if (ID == 0) {
        swal({
            title: 'Are you sure?',
            text: 'You want to remove all events!?',
            type: 'warning',
            showCancelButton: true,
            closeOnConfirm: true,
        }, function() {
            ipmiPost(EventDelete, {archive: Archive, event: ID}, function() {
                $('#tblEvent tbody').empty();
                if (Archive == 1)
                    ipmiRefreshArchiveTableIfPresent();
            });
        });
    } else {
        var trID = $('#'+ID);
        ipmiPost(EventDelete, {archive: Archive, event: ID},
            function() {
                //animate removal of table row
                trID
                .children('td')
                .animate({ padding: 0 })
                .wrapInner('<div />')
                .children()
                .slideUp(function() {
                    trID.remove();
                    $('#tblEvent').trigger('update');
                });
            if (Archive == 1)
                ipmiRefreshArchiveTableIfPresent();
        });
    }
}

</script>
