#!/usr/bin/php
<?php
##############################
######  DEAMON SECTION  ######
##############################
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_options.php';
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_settings_fan.php';
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_fan_curve.php';
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_drives.php';
require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';

$dynamix_config = ipmi_parse_dynamix_config();
$display = ipmi_array_get($dynamix_config, 'display', []);
$debug = FALSE;

set_time_limit(0);
$prog     = pathinfo(__FILE__, PATHINFO_FILENAME);
$lockfile = "/var/run/{$prog}.pid";
$log      = '/var/log/ipmifan';
openlog($prog, LOG_PID | LOG_PERROR, LOG_LOCAL0);

$usage = <<<EOF

Process settings in ipmi plugin fan config.
Control fans based on config values and [options].

Usage: $prog [options]

  -a, --auto       set fans to auto
      --full       set fans to full speed
  -q, --quiet      suppress all messages
      --debug      turn on debugging
      --daemon     run in the background (compatibility mode)
      --help       display this help and exit
      --quit       stop daemon if running
      --version    output version information and exit


EOF;

$shortopts = 'adfq';
$longopts = [
    'auto',
    'daemon',
    'debug',
    'full',
    'help',
    'quit',
    'quiet',
    'version'
];
$args = getopt($shortopts, $longopts);

if (array_key_exists('help', $args)) {
    echo $usage.PHP_EOL;
    exit(0);
}

if (array_key_exists('version', $args)) {
    echo 'IPMI Fan Control: 1.0'.PHP_EOL;
    exit(0);
}

$arga   = (array_key_exists('a', $args) || array_key_exists('auto', $args));
$argf   = (array_key_exists('full', $args));
$argq   = (array_key_exists('q', $args) || array_key_exists('quiet', $args));
$debug  = (array_key_exists('debug', $args));
$daemon = (array_key_exists('d', $args) || array_key_exists('daemon', $args));
$quit   = (array_key_exists('quit', $args));

if (ipmi_is_service_running($lockfile)) {
    $lock_pid = ipmi_read_pidfile($lockfile);
    if($quit){
        fanlog('Stopping Fan Control');
        syslog(LOG_INFO, "killing daemon with PID [$lock_pid]");
        ipmi_stop_service($lockfile);
        autofan();
        exit(0);
    } else {
        echo "$prog is already running [$lock_pid]".PHP_EOL;
        exit(0);
    }
} else {
    $lock_pid = ipmi_read_pidfile($lockfile);
    if($quit){
        if ($lock_pid > 0)
            echo "$lock_pid is not currently running".PHP_EOL;
        else
            echo "$prog not currently running".PHP_EOL;
        @unlink($lockfile);
        exit(0);
    }

    ipmi_write_pidfile($lockfile);
}

register_shutdown_function(function () use ($lockfile) {
    if (ipmi_read_pidfile($lockfile) === getmypid())
        @unlink($lockfile);
});

if($arga){
        autofan();
        exit(0);
}

if($argf){
        fullfan();
        exit(0);
}

if (!$board_file_status) {
    $msg = "Your $board motherboard is not supported or setup yet";
    logger($msg, $argq);
    exit(1);
}

if($daemon)
    logger('The --daemon flag is now a compatibility alias; use fanctrl_start for background execution.', $argq);

#############################################
# ASRock
# ipmi-raw 00 3a 01 00 00 00 00 00 00 00 00
# ipmi-raw 00 3a 01 AA BB CC DD EE FF GG HH
# 00 = smartfan mode
# 01 - 64  = 1% - 100%
#############################################

#############################################
# ASRock Dual Socket
# ipmi-raw 00 3a 01 CPU_1_OVERRIDE CPU_1 REAR_1 FRONT_1 FRONT_2 FRONT_3
# ipmi-raw 00 3a 11 CPU_2_OVERRIDE CPU_2 REAR_2 FRONT_4
# ipmi-raw 00 3a 01 00 AA BB CC DD EE
# ipmi-raw 00 3a 11 00 AA BB CC
#############################################

#############################################
# ASRock Rack d6/d8 profile (ROMED8U-2T)
# ipmi-raw 00 3a d6 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
# ipmi-raw 00 3a d6 AA BB CC DD EE FF GG HH II JJ KK LL MM NN OO PP
# Auto/manual uses d8 and PWM writes must stay at or above 16
#############################################

#############################################
# Supermicro X10/X11
# ipmi-raw 00 30 70 66 01 00 64
# ipmi-raw 00 30 70 66 AA BB CC
#
# AA
# 00 - Get value
# 01 - Set value
#
# BB
# 00 - FAN 1/2/3/4 or CPU_FAN1/2
# 01 - FAN A or SYS_FAN1/2/3
#
# CC
# 00 to 64 - Set Speed (0-64)
#############################################

#############################################
# Supermicro X9
# ipmi-raw 00 30 91 5A 3 00 FF
# ipmi-raw 00 30 91 5A 3 BB CC
#
# BB
# 10 - FAN 1/2/3/4
# 11 - FAN A
#
# CC
# 00 to FF - Set Speed (0-255)
#############################################

#############################################
# Dell
# raw'    => '30 30 02 FF', # + value 01-64 for % FF is all or ID
#'auto'   => '30 30 01 00',
#'manual' => '30 30 01 01',
#'full'   => '30 30 02 FF 64',
# 01 - 64  = 1% - 100%
#############################################

##############################
###### FUNCTION SECTION ######
##############################

/* logger*/
function logger($msg, $quiet = false) {
    syslog(LOG_INFO, $msg);
    if (!$quiet)
        echo PHP_EOL.$msg.PHP_EOL;
}

/* logfile */
function fanlog($msg) {
    global $log;
    $msg = date('Y-m-d H:i:s').' '.$msg.PHP_EOL;
    file_put_contents($log,$msg,FILE_APPEND);
}

/* debug */
function debug($m){
  global $prog, $debug;
  if($debug){
    $STDERR = fopen('php://stderr', 'w+');
    fwrite($STDERR, $m.PHP_EOL);
    fclose($STDERR);
  }
}

function ipmifan_log_command_result($result) {
    global $debug;

    if ($debug)
        fanlog($result['command']);

    if (!$result['success'] && trim((string)$result['text']) !== '')
        fanlog(trim((string)$result['text']));
}

function ipmifan_run_raw($raw, $payload='') {
    global $fanopt_args;

    $args = array_merge(
        ipmi_hex_tokens($raw),
        ipmi_hex_tokens($payload),
        $fanopt_args
    );

    $result = ipmi_run_process('ipmi-raw', $args);
    ipmifan_log_command_result($result);
    return $result;
}

function ipmifan_read_raw_mode($raw) {
    $result = ipmifan_run_raw($raw);
    return ipmi_last_token($result['text']);
}

function is_asrock_family() {
    global $board;
    return ($board === 'ASRock' || $board === 'ASRockRack');
}

function board_entry_key($index=0) {
    global $board;
    return ($index == 0) ? $board : $board.$index;
}

function get_board_entry($index=0) {
    global $board_json;
    $key = board_entry_key($index);
    return (isset($board_json[$key]) && is_array($board_json[$key])) ? $board_json[$key] : [];
}

function asrock_board_entries() {
    global $cmd_count;
    $entries = [];

    for($i = 0; $i <= $cmd_count; $i++)
        $entries[$i] = get_board_entry($i);

    return $entries;
}

function asrock_command_specs($command_key, $fallback_key='') {
    $commands = [];

    foreach(asrock_board_entries() as $entry){
        $raw = isset($entry['raw']) ? $entry['raw'] : '';
        $payload = !empty($entry[$command_key]) ? $entry[$command_key] : '';

        if (empty($payload) && !empty($fallback_key))
            $payload = !empty($entry[$fallback_key]) ? $entry[$fallback_key] : '';

        if (!empty($raw) && !empty($payload))
            $commands[] = ['raw' => $raw, 'payload' => $payload];
    }

    return $commands;
}

function build_asrock_pwm_segment($pwm, $fan_count, $pwm_prefix) {
    global $board_model, $cmd_count;

    if($board_model == 'EP2C612 WS' && empty($pwm_prefix))
        return " $pwm";

    if($cmd_count !== 0 && $fan_count == 0 && empty($pwm_prefix)){
        if($pwm == '00')
            return ' 00 00';

        return " 01 $pwm";
    }

    return " $pwm";
}

function build_asrock_pwm_payload($hex, $pwm_prefix) {
    $payload = trim($hex);
    if (!empty($pwm_prefix))
        $payload = trim($pwm_prefix.' '.$payload);

    return $payload;
}

function has_asrock_manual_profile() {
    if (!is_asrock_family())
        return false;

    foreach(asrock_board_entries() as $entry){
        if (!empty($entry['manual']))
            return true;
    }

    return false;
}

function ipmifan_run_commands($commands, $echo_output=false) {
    $combined_output = [];

    foreach ($commands as $command) {
        $result = ipmifan_run_raw(
            ipmi_array_get($command, 'raw', ''),
            ipmi_array_get($command, 'payload', '')
        );

        if (!empty($result['text']))
            $combined_output[] = trim((string)$result['text']);
    }

    if ($echo_output && !empty($combined_output))
        echo implode(PHP_EOL, $combined_output).PHP_EOL;
}

/* auto fan */
function autofan() {
    global $board_json, $board;
    fanlog('Setting fans to auto');
    switch($board) {
        case "ASRock":
        case "ASRockRack":
            ipmifan_run_commands(asrock_command_specs('auto'));
            break;
        case "Supermicro":
            $auto = $board_json[$board]['auto'];
            $mode = ipmifan_read_raw_mode('00 30 45 00');
            ipmifan_run_raw($auto, $mode);
            break;
        case "Dell":
            $auto = $board_json[$board]['auto'];
            ipmifan_run_raw($auto);
            break;
    }
}

/* manual fan */
function manualfan() {
    global $board_json, $board;
    fanlog('Setting fans to manual');
    switch($board) {
        case "ASRock":
        case "ASRockRack":
            ipmifan_run_commands(asrock_command_specs('manual', 'auto'));
            break;
        case "Supermicro":
            $auto = $board_json[$board]['auto'];
            $mode = ipmifan_read_raw_mode('00 30 45 00');
            ipmifan_run_raw($auto, $mode);
            break;
        case "Dell":
            $manual = $board_json[$board]['manual'];
            ipmifan_run_raw($manual);
            break;
    }
    sleep(10) ;
}

/* full speed fan */
function fullfan() {
    global $board_json, $board;
    fanlog('Setting fans to full speed');
    switch($board) {
        case "ASRock":
        case "ASRockRack":
            ipmifan_run_commands(asrock_command_specs('full'), true);
            break;
        case "Supermicro":
            $full = $board_json[$board]['full'];
            ipmifan_run_raw($full);
            break;
        case "Dell":
            $full = $board_json[$board]['full'];
            ipmifan_run_raw($full);
            break;  
    }
    sleep(10);
}

function ipmifan_parse_smartctl_temperature($output) {
    foreach ($output as $line) {
        if (stripos($line, 'Temperature_Cel') === false)
            continue;

        $tokens = preg_split('/\s+/', trim((string)$line));
        if (empty($tokens))
            continue;

        return preg_replace('/\s+/', '', (string)$tokens[count($tokens) - 1]);
    }

    return '';
}

/* get highest temp of hard drives */
function get_highest_temp(){
    global $hddignore;
    $ignore = array_flip(explode(',', $hddignore));

    //get UA devices
    $ua_json = '/var/state/unassigned.devices/hdd_temp.json';
    $ua_devs = ipmi_read_json_config($ua_json);

    //get all hard drives
    $disksini = ipmi_read_ini_config('/var/local/emhttp/disks.ini', true);
    $devsini = ipmi_read_ini_config('/var/local/emhttp/devs.ini', true);
    if ($devsini) $hdds = array_merge($disksini, $devsini); else $hdds = $disksini ;
    unset($hdds['flash']);

    $highest_temp = 0;
    foreach ($hdds as $hdd) {

        if (!array_key_exists($hdd['id'], $ignore)) {
            $temp = 0;
            if(array_key_exists('temp', $hdd))
                $temp = $hdd['temp'];
            elseif(!empty($ua_devs)){
                $ua_key = "/dev/".$hdd['device'];
                $temp = (array_key_exists($ua_key, $ua_devs)) ? $ua_devs[$ua_key]['temp'] : 0;
            }else{
                $smartctl = ipmi_run_process('smartctl', ['-A', '-n', 'standby', "/dev/{$hdd['device']}"], false);
                $temp = ipmifan_parse_smartctl_temperature($smartctl['output']);
            }

            $highest_temp = ($temp > $highest_temp) ? $temp : $highest_temp;
        }
    }
    debug("Highest temp is {$highest_temp}ºC");
    return $highest_temp;
}

/* get fan and temp sensors */
function ipmi_fan_sensors() {
    global $ipmi, $fanopt_args, $hdd_temp;

    // return empty array if no ipmi detected or network options
    if(!$ipmi && empty($fanopt_args))
        return [];

    $result = ipmi_run_process(
        '/usr/sbin/ipmi-sensors',
        array_merge(['--comma-separated-output', '--no-header-output', '--interpret-oem-data'], $fanopt_args),
        false
    );
    $output = $result['output'];
    $return_var = $result['exit_code'];

    // return empty array if error
    if($return_var)
        return [];

    // add hard drive temp as a sensor
    $output[] = "99,HDD Temperature,Temperature, $hdd_temp,C,Ok";

    // key names for ipmi sensors output
    $keys = ['ID', 'Name', 'Type', 'Reading', 'Units', 'Event'];
    $sensors = [];

    foreach($output as $line){

    /// add sensor keys as keys to ipmi sensor output
        $sensor_raw = explode(",", $line);
        $size_raw = sizeof($sensor_raw);
        $sensor = ($size_raw < 6) ? []: array_combine($keys, array_slice($sensor_raw,0,6,true));

        if ($sensor['Type'] === 'Temperature' || $sensor['Type'] === 'Fan')
            $sensors[$sensor['ID']] = $sensor;
    }
    return $sensors; // sensor readings
    unset($sensors);
}

##############################
#####  PROGRAM SECTION  ######
##############################

$MD5                = md5_file($fancfg_file);
$hdd_temp           = get_highest_temp();
$sensors            = ipmi_fan_sensors();
$ipmipoll           = ($fanpoll <= $hddpoll) ? $fanpoll : $hddpoll;
$fan_poll_remaining = $fanpoll * 10;
$hdd_poll_remaining = $hddpoll * 10;
$current_hex        = [];
$current_pwm        = '';
$current_pwm2       = '';

fanlog('Starting Fan Control');
fanlog("Board: $board Board Model: $board_model");

if($board == 'Supermicro'){
    fanlog("SM Board selection: $smboard_model");
    fullfan();
}
if($board == 'Dell'){
    manualfan();
}
if(has_asrock_manual_profile()){
    manualfan();
}

while(TRUE){ while(TRUE){
####  DO YOUR STUFF HERE  ####

    /* Refresh hdds and hdd temp if hdd poll time is expired */
    if ($hdd_poll_remaining <= 0) {
        $hdd_poll_remaining = $hddpoll * 10;
        $hdd_temp  = get_highest_temp();
        $sensors['99']['Reading'] = $hdd_temp;
    }
    /* Get sensor info if fan sensor poll time is expired */
    if ($fan_poll_remaining <= 0) {
        $fan_poll_remaining = $fanpoll * 10;
        $sensors = ipmi_fan_sensors();
    }

    for($i = 0; $i <= $cmd_count; $i++){
        $entry  = get_board_entry($i);
        $raw    = $entry['raw'];
        $fans   = is_array($entry['fans']) ? $entry['fans'] : [];
        $pwm_prefix = isset($entry['pwm_prefix']) ? trim($entry['pwm_prefix']) : '';
        $pwm_min = isset($entry['pwm_min']) ? intval($entry['pwm_min']) : 0;
        $hex    = '';
        $msg    = 'Fan:Temp';
        $commands = [];
        $exec   = false;
        $slot_index  = 0;
       # var_dump($fans,$raw) ;

        foreach($fans as $fan => $value){

            $temp = isset($fancfg["TEMP_$fan"]) ? $fancfg["TEMP_$fan"] : '';
         #   echo "temp:".$temp;
            if(!empty($temp)) {
                $fanmin  = (isset($fancfg["FANMIN_$fan"])) ? intval($fancfg["FANMIN_$fan"])  : 16;
                $fanmax  = (isset($fancfg["FANMAX_$fan"])) ? intval($fancfg["FANMAX_$fan"])  : $range;
                $fanmino  = (isset($fancfg["FANMINO_$fan"])) ? intval($fancfg["FANMINO_$fan"])  : 16;
                $fanmaxo  = (isset($fancfg["FANMAXO_$fan"])) ? intval($fancfg["FANMAXO_$fan"])  : $range;
                $reading = floatval($sensors[$temp]['Reading']);
                $name    = htmlspecialchars($sensors[$temp]['Name']);
                $use_override = false;
                if ($temp == "99" && $reading <= 0) {
                    if (isset($fancfg["TEMPHDD_$fan"]) &&  $fancfg["TEMPHDD_$fan"] != 0) {
                    $temp=    $fancfg["TEMPHDD_$fan"] ;
                    $reading = floatval($sensors[$temp]['Reading']);
                    $name    = "HDD Spundown using ".htmlspecialchars($sensors[$temp]['Name']);
                    $use_override = true;
                    }  
                }
                if ($use_override) {
                    $curve_pts = ipmi_fan_curve_override_points($fancfg, $fan, $range);
                    $res = ipmi_fan_curve_compute_pwm($reading, $curve_pts, $range, $fanmino, $fanmaxo);
                    $pwm = $res['pwm'];
                    $pct = $res['pct'];
                } else {
                    $curve_pts = ipmi_fan_curve_primary_points($fancfg, $fan, $range);
                    $res = ipmi_fan_curve_compute_pwm($reading, $curve_pts, $range, $fanmin, $fanmax);
                    $pwm = $res['pwm'];
                    $pct = $res['pct'];
                }
                if (is_asrock_family() && $pwm_min > 1 && $pwm < $pwm_min){
                    $pwm = $pwm_min;
                    $pct = $pwm_min/$range;
                }
                //convert pwm to hexadecimal
                if($range == 255){
                    $pwm = dechex($pwm);
                }

                //pad pwm to 2 places
                $pwm = str_pad($pwm, 2, '0', STR_PAD_LEFT);

                //add fan, value, temp sensor name and reading
                $pct  = str_pad(round(($pwm / $range) * 100), 2, ' ', STR_PAD_LEFT);
                if ($reading <= 0) $mytemp = "Spundown" ; else $mytemp = str_replace([" ","&#8201;&#176;"],["",""],my_temp($reading));
                $msg .= ", {$fan}({$pct}%):".str_replace('Temperature','Temp',$name)."($mytemp)";

           }else{
                $pwm = (is_asrock_family() && $pwm_min > 1) ? str_pad($pwm_min, 2, '0', STR_PAD_LEFT) : '00';
           }

           switch($board) {
            case "ASRock":
            case "ASRockRack":
                $hex .= build_asrock_pwm_segment($pwm, $slot_index, $pwm_prefix);
                break;
            case "Supermicro":
                if(($value == '00' || $value == '10') && $current_pwm !== $pwm && $pwm !== '00'){
                    $commands[] = ['raw' => trim($raw.' '.$value.' '.$pwm)];
                    $current_pwm  = $pwm;
                    $exec = true;
                }
                if(($value == '01' || $value == '11') && $current_pwm2 !== $pwm && $pwm !== '00'){
                    $commands[] = ['raw' => trim($raw.' '.$value.' '.$pwm)];
                    $current_pwm2 = $pwm;
                    $exec = true;
                }
                break;
            case "Dell":
                if(($value == '00' || $value == '10') && $current_pwm !== $pwm && $pwm !== '00'){
                    $commands[] = ['raw' => trim($raw.' '.$pwm)];
                    $current_pwm  = $pwm;
                    $exec = true;
                }
                break;
            }
            $slot_index++;
        }
        switch($board) {
            case "ASRock":
            case "ASRockRack":
            //compare last value to new value for Asrock boards
            $payload = build_asrock_pwm_payload($hex, $pwm_prefix);

            if(!array_key_exists($i, $current_hex) || $current_hex[$i] !== $hex){
                $commands[] = ['raw' => $raw, 'payload' => $payload];
                $current_hex[$i] = $hex;
                $exec = true;
            }
            break;
        }

        // execute command if exec set
        if($exec){
            ipmifan_run_commands($commands);
            //log changes
            fanlog($msg);
        }
    }
    /* print variable */
    $defined_vars = get_defined_vars();

    foreach (array('_GET','_POST','_COOKIE','_FILES','argv','argc','_SERVER') as $i)
        unset($defined_vars[$i]);

    if($debug)
        debug("\nDECLARED VARIABLES:\n".print_r($defined_vars, true));

    unset($defined_vars);

    $time1 = time();

    for ($i=0; $i < $ipmipoll ; $i++) {
        sleep(10);
        $fan_poll_remaining = $fan_poll_remaining - 10;
        $hdd_poll_remaining = $hdd_poll_remaining - 10;

        $MD5_new = md5_file($fancfg_file);
        if((file_exists($fancfg_file)) && ($MD5_new != $MD5)){
            $msg = 'fan control config file updated, reloading settings';
            $fancfg = ipmi_load_fan_config();
            logger($msg, $argq);
            $MD5 = $MD5_new;
            fanlog($msg);
            break;
        }
    }
    debug("Sleep ".(time()-$time1)." seconds.");

######  END OF SECTION  ######
    };
};
