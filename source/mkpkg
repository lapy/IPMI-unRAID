#!/bin/bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: mkpkg directory_name [version]"
    exit 1
fi

ROOT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
SOURCE_DIR="${ROOT_DIR}/${1}"
PLUGIN="$(basename "${SOURCE_DIR}")"
ARCHIVE_DIR="$(dirname "${ROOT_DIR}")/archive"
PLUGIN_TEMPLATE="$(dirname "${ROOT_DIR}")/plugin/${PLUGIN}.plg"
VERSION_INPUT="${2:-${PLUGIN_VERSION:-$(date +"%Y.%m.%d")}}"
ARCH_SUFFIX="-x86_64-1"
TMPDIR="$(mktemp -d "/tmp/${PLUGIN}.pkg.XXXXXX")"
STAGE_DIR="${TMPDIR}/stage"
PKGROOT_DIR="${STAGE_DIR}/pkgroot"
MANIFEST_STAGE="${STAGE_DIR}/${PLUGIN}.plg"

cleanup() {
    rm -rf "${TMPDIR}"
}
trap cleanup EXIT

if [ ! -d "${SOURCE_DIR}" ]; then
    echo "Source directory not found: ${SOURCE_DIR}"
    exit 1
fi

if [ ! -f "${PLUGIN_TEMPLATE}" ]; then
    echo "Plugin manifest not found: ${PLUGIN_TEMPLATE}"
    exit 1
fi

mkdir -p "${ARCHIVE_DIR}" "${PKGROOT_DIR}"

VERSION="${VERSION_INPUT}"
for suffix in '' a b c d e f g h; do
    CANDIDATE_VERSION="${VERSION_INPUT}${suffix}"
    CANDIDATE_PACKAGE="${ARCHIVE_DIR}/${PLUGIN}-${CANDIDATE_VERSION}${ARCH_SUFFIX}.txz"
    if [ ! -f "${CANDIDATE_PACKAGE}" ]; then
        VERSION="${CANDIDATE_VERSION}"
        break
    fi
done

PACKAGE_PATH="${ARCHIVE_DIR}/${PLUGIN}-${VERSION}${ARCH_SUFFIX}.txz"
MD5_PATH="${ARCHIVE_DIR}/${PLUGIN}-${VERSION}${ARCH_SUFFIX}.md5"
MANIFEST_PATH="${ARCHIVE_DIR}/${PLUGIN}-${VERSION}.plg"

build_package() {
    if command -v makepkg >/dev/null 2>&1; then
        (
            cd "${PKGROOT_DIR}"
            makepkg -l y -c y "${PACKAGE_PATH}"
        )
        return 0
    fi

    echo "makepkg not found; using portable tar/xz packaging fallback"
    (
        cd "${PKGROOT_DIR}"
        tar \
            --sort=name \
            --mtime='UTC 1970-01-01' \
            --owner=0 \
            --group=0 \
            --numeric-owner \
            -c . | xz -z -9 -T0 > "${PACKAGE_PATH}"
    )
}

(
    cd "${SOURCE_DIR}"
    find . -type f ! \( -iname "pkg_build.sh" -o -iname "sftp-config.json" -o -iname ".DS_Store" \) -print0 \
        | while IFS= read -r -d '' file; do
            mkdir -p "${PKGROOT_DIR}/$(dirname "${file}")"
            cp -f "${file}" "${PKGROOT_DIR}/${file}"
        done
)

cp "${PLUGIN_TEMPLATE}" "${MANIFEST_STAGE}"
sed -i -e "s#\(ENTITY\s*version[^\"]*\).*#\1\"${VERSION}\">#" "${MANIFEST_STAGE}"
if ! grep -q "###${VERSION}" "${MANIFEST_STAGE}"; then
    sed -i "/##&name/a\\###${VERSION}\n- Packaged build generated from staging." "${MANIFEST_STAGE}"
fi
cp -f "${MANIFEST_STAGE}" "${MANIFEST_PATH}"

build_package

(
    cd "${ARCHIVE_DIR}"
    md5sum "$(basename "${PACKAGE_PATH}")" > "${MD5_PATH}"
)

PACKAGE_SUM="$(cut -d' ' -f1 "${MD5_PATH}")"
VERIFY_SUM="$(md5sum "${PACKAGE_PATH}" | cut -d' ' -f1)"
if [ "${PACKAGE_SUM}" != "${VERIFY_SUM}" ]; then
    echo "Checksum mismatch for ${PACKAGE_PATH}"
    rm -f "${PACKAGE_PATH}" "${MD5_PATH}" "${MANIFEST_PATH}"
    exit 1
fi

echo "Built package: ${PACKAGE_PATH}"
echo "Built checksum: ${MD5_PATH}"
echo "Built manifest: ${MANIFEST_PATH}"
