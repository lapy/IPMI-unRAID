<form id="autoload-form" method="POST" action="/update.php" target="progressFrame">
    <input type="hidden" id="autoload" name="LOADCFG" value="disable" />
    <input type="hidden" name="#file" value="ipmi/ipmi.cfg" />
    <input type="hidden" name="#command" value="" />
</form>

<div class="ipmi-shell ipmi-editor-shell">
    <div class="ipmi-tool-header">
        <div>
            <h1>IPMI Configuration Editor</h1>
            <p>Inspect or edit the stored BMC configuration, sensor configuration, or board JSON with a safer editing shell and clearer actions.</p>
        </div>
    </div>

    <div class="ipmi-alert ipmi-alert--warning">
        <p><strong>Edit carefully.</strong> These files can change credentials, networking, sensor thresholds, boot devices, and other low-level BMC behavior.</p>
        <p><strong>Editor shortcuts:</strong> Ctrl/Cmd-F search, Ctrl/Cmd-G next, Shift-Ctrl/Cmd-G previous, Shift-Ctrl/Cmd-F replace, Shift-Ctrl/Cmd-R replace all.</p>
    </div>

    <section class="ipmi-section-card">
        <form id="cfgform" method="POST">
            <div class="ipmi-editor-toolbar">
                <select id="editfile" name="editfile">
                    <option>Select Config...</option>
                    <option>Config</option>
                    <option>Sensors</option>
                    <option>Json</option>
                </select>
                <span class="status" id="load-switch" hidden><input type="checkbox" id="autoload-switch"></span>
            </div>

            <textarea id="editcfg" name="ipmicfg" placeholder="Select IPMI Configuration above." autocomplete="" focus></textarea>
            <input type="hidden" id="commit" name="commit" value="1" />
            <input type="hidden" id="ipmiconfig" name="config" value="1" />
            <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>" />

            <div class="ipmi-actions">
                <input type="button" value="Revert" id="btnRevert" title="Reset the stored IPMI config file to the existing BMC config" />
                <input type="button" value="Save" id="btnSubmit" title="Save IPMI configuration changes to the BMC" />
                <input type="button" value="Cancel" id="btnCancel" />
                <span class="warning"><i class="fa fa-warning icon warning"></i> Live BMC configuration changes apply immediately when saved.</span>
            </div>
        </form>
    </section>
</div>

<script src="<?=autov('/plugins/ipmi/js/codemirror/codemirror.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/dialog.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/placeholder.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/show-hint.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/properties.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/anyword-hint.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/searchcursor.min.js');?>"></script>
<script src="<?=autov('/plugins/ipmi/js/codemirror/search.min.js');?>"></script>
<script src="<?=autov('/webGui/javascript/jquery.switchbutton.js');?>"></script>
<script>
window.IPMI_CSRF_TOKEN = '<?=htmlspecialchars($var['csrf_token']);?>';
</script>
<script src="<?=autov('/plugins/ipmi/js/ipmi-api.js');?>"></script>

<script>
$(function(){
    //autoload switch
    $('#autoload-switch').switchButton({
        labels_placement: 'left',
        on_label: 'Load Config @ unRAID Start',
        off_label: 'Load Config @ unRAID Start',
        checked: ("<?=$loadcfg;?>" == 'enable')
    })
    .change(function () {
        setAutoLoad();
        $.post('/update.php', $('#autoload-form').serializeArray());
    });

    setAutoLoad();

    $('#btnCancel').click(function() {
        $.cookie('one', 'tab1', { expires:null, path: '/'});
        location = '/Settings/IPMI';
    });

    $('#editfile').on('change', function () {
        var Config = $('#editfile')[0].selectedIndex -1;

        if (Config == 1)
            $('#load-switch').show();
        else
            $('#load-switch').hide();

        if (Config != -1){
            $('#ipmiconfig').val(Config);
            ipmiPost('/plugins/ipmi/include/ipmi_config.php', {ipmicfg:null, config:Config}, function (data) {
                    editor.setValue(data.config || '');
                }
            );
        }else{
            editor.setValue('');
        }
    });

    var editor = CodeMirror.fromTextArea($('#editcfg')[0], {
        theme: '<?=($display["theme"] == 'white' || $display["theme"] == 'azure') ? "default" : "dracula";?>',
        mode: 'properties',
        lineNumbers: true,
        gutters: ['CodeMirror-linenumbers'],
        extraKeys: {
            'Ctrl-Space': 'autocomplete'
        },
        hintOptions: {}
    });

    $('#tab3').click(function () {
        editor.refresh();
    });

    // save config and commit to bmc
    $('#btnSubmit').click(function () {
        editor.save();
        commitConfig();
    });

    // revert saved config file to bmc stored config
    $('#btnRevert').click(revertConfig);
});


function commitConfig() {
    var Config = $('#editfile')[0].selectedIndex -1;
    if (Config != -1){
        $('#ipmiconfig').val(Config);
        ipmiPost('/plugins/ipmi/include/ipmi_config.php', $('#cfgform').serializeArray(),function (data, response) {
            swal({title:'IPMI Sensors Configuration',text:response.message || 'saved',type:'success',closeOnConfirm: true,},function() {
                location = '/Settings/IPMI';
            });
        }, function(response) {
            swal({title:'IPMI Sensors Configuration',text:ipmiResponseText(response),type:'error'});
        });
    }
}

function revertConfig() {
    var Config = $('#editfile')[0].selectedIndex -1;
    if (Config != -1){
        ipmiPost('/plugins/ipmi/include/ipmi_config.php', {ipmicfg:null, config:Config}, function (data, response) {
            swal({title:'IPMI Sensors Configuration',text:response.message || 'reloaded from bmc',type:'success',closeOnConfirm: true,},function() {
                location.reload(true);
            });
        }, function(response) {
            swal({title:'IPMI Sensors Configuration',text:ipmiResponseText(response),type:'error'});
        });
    }
}

function setAutoLoad() {
    if ($('#autoload-switch')[0].checked) {
        $('#autoload').val('enable');
    }else{
        $('#autoload').val('disable');
    }
}

</script>
