function clearFanLOG() {
    ipmiPost('/plugins/ipmi/include/fanlog_clear.php', {}, function() {
        $('#fanlog-size').html('0');
    });
}

function DDCheckList(Select, Values) {
    $(Select).dropdownchecklist({
        emptyText: 'Nothing Available',
        icon: {placement: 'right', toOpen: 'ui-icon-triangle-1-s', toClose: 'ui-icon-triangle-1-n'},
        width: 300,
        explicitClose: 'close',
        firstItemChecksAll: true,
        textFormatFunction: function() { return 'Select items'; },
        onComplete: function(selector){
            var values = '';
            var unchecked = 1;
            var size = selector.options.length;
            for (var i = 1; i < size; i++) {
                if ((selector.options[i].selected == false) && (selector.options[i].value !== '')) {
                    if (values != '')
                        values += ',';
                    values += selector.options[i].value;
                    unchecked++;
                }
            }
            $(Values).val(values);

            if (size == unchecked)
                $(Select + '-svc').val('disable');
            else
                $(Select + '-svc').val('enable');
        }
    });
}

function renderFanValidation(errors) {
    if (!errors.length) {
        $('#fan-validation-alert').hide().empty();
        return;
    }

    var html = '<p><strong>Fan configuration needs attention.</strong></p><ul class="ipmi-list">';
    $.each(errors.slice(0, 8), function(_, message) {
        html += '<li>' + message + '</li>';
    });
    html += '</ul>';

    $('#fan-validation-alert').html(html).show();
}

function validateFanConfig(event) {
    var errors = [];

    if ($('#FANCONTROL').val() === 'enable' && "<?=$board_file_status;?>" == false && ("<?=$board;?>" === 'ASRock' || "<?=$board;?>" === 'ASRockRack')) {
        errors.push('Run Scan Headers before enabling fan control on this board.');
    }

    $('.ipmi-fan-card').each(function() {
        var fanName = $(this).data('fanName');
        var tempSensor = $('select[name="TEMP_' + fanName + '"]').val();
        var overrideSensor = $('select[name="TEMPHDD_' + fanName + '"]').val();

        if (tempSensor && tempSensor !== '0') {
            var low = parseInt($('select[name="TEMPLO_' + fanName + '"]').val(), 10);
            var high = parseInt($('select[name="TEMPHI_' + fanName + '"]').val(), 10);
            var min = parseInt($('select[name="FANMIN_' + fanName + '"]').val(), 10);
            var max = parseInt($('select[name="FANMAX_' + fanName + '"]').val(), 10);

            if (low >= high) errors.push(fanName + ': low threshold must be below high threshold.');
            if (min > max) errors.push(fanName + ': minimum fan speed must not exceed maximum fan speed.');
        }

        if (overrideSensor && overrideSensor !== '0') {
            var lowOverride = parseInt($('select[name="TEMPLOO_' + fanName + '"]').val(), 10);
            var highOverride = parseInt($('select[name="TEMPHIO_' + fanName + '"]').val(), 10);
            var minOverride = parseInt($('select[name="FANMINO_' + fanName + '"]').val(), 10);
            var maxOverride = parseInt($('select[name="FANMAXO_' + fanName + '"]').val(), 10);

            if (lowOverride >= highOverride) errors.push(fanName + ': HDD override low threshold must be below the high threshold.');
            if (minOverride > maxOverride) errors.push(fanName + ': HDD override minimum fan speed must not exceed the maximum.');
        }
    });

    renderFanValidation(errors);

    if (!errors.length)
        return true;

    if (event)
        event.preventDefault();

    swal({
        title: 'Fan configuration needs attention',
        text: errors.slice(0, 8).join('\n'),
        type: 'error'
    });
    return false;
}

function initDriveDropdown(remove) {
    if (remove)
        $('#select-drives').dropdownchecklist('destroy');

    DDCheckList('#select-drives', '#HDDIGNORE');
}

function checkFANCTRL() {
    if ($('#FANCONTROL')[0].selectedIndex < 1) {
        $('#FANCMD').val('/usr/local/emhttp/plugins/ipmi/scripts/fanctrl_stop');
    } else {
        $('#FANCMD').val('/usr/local/emhttp/plugins/ipmi/scripts/fanctrl_start');
    }

    if ("<?=$fanctrl_run;?>" == true) {
        $('.fanctrl-run').prop('disabled', true);
        $('#btnFANApply').prop('disabled', false);
    } else {
        $('.fanctrl-run').prop('disabled', false);
        $('#btnFANApply').prop('disabled', false);
    }
}

function checkBoard() {
    if ("<?=$board_file_status;?>" == false) {
        swal({
            title: 'Header mapping required',
            text: 'Run Scan Headers before enabling fan control. The scan briefly changes fan duty levels so the plugin can determine the correct header mapping.',
            type: 'warning',
            closeOnConfirm: true
        });
    }
}

function syncControlledFields(controlName) {
    var control = $('[name="' + controlName + '"]');
    if (!control.length)
        return;

    var enabled = control.val() !== '0';
    $('.' + controlName).prop('disabled', !enabled);
}

function updateOverrideAvailability(fanName) {
    var sensor = $('select[name="TEMP_' + fanName + '"]');
    var override = $('select[name="TEMPHDD_' + fanName + '"]');
    if (!sensor.length || !override.length)
        return;

    var allowOverride = (sensor.val() === '99');
    override.prop('disabled', !allowOverride);
    if (!allowOverride)
        override.val('0');

    syncControlledFields('TEMPHDD_' + fanName);
}

function syncAllFanControls() {
    $('.fanctrl-temp').each(function() {
        syncControlledFields($(this).attr('name'));
    });

    $('.ipmi-fan-card').each(function() {
        updateOverrideAvailability($(this).data('fanName'));
    });
}

function updateFanAdvancedHint() {
    var adv = $.cookie('fanctrl_view_mode') == 'advanced';
    $('#fan-advanced-mode-hint').text(adv
        ? 'Advanced: every threshold and duty control is shown. The summary strip above tracks mapping, custom curves, and HDD overrides across all headers.'
        : 'Basic: each card shows a readable summary. Enable Advanced tuning to edit thresholds, duties, and spindown overrides.');
}

function refreshFanConfiguratorBar() {
    var $ctx = $('#fan-configurator-context');
    if (!$ctx.length)
        return;

    var cards = $('.ipmi-fan-card').length;
    var needMap = $('.ipmi-fan-card.needs-mapping').length;
    var overrides = 0;
    var customCurves = 0;

    $('.ipmi-fan-card').each(function() {
        var fan = $(this).data('fanName');
        var hdd = $('select[name="TEMPHDD_' + fan + '"]').val();
        if (hdd && hdd !== '0')
            overrides++;

        var temp = $('select[name="TEMP_' + fan + '"]').val();
        if (temp && temp !== '0')
            customCurves++;
    });

    $('#fan-ctx-headers').text(cards + ' fan header' + (cards === 1 ? '' : 's'));

    var $map = $('#fan-ctx-mapping');
    if (needMap) {
        $map.removeClass('ipmi-fan-context-pill--ok').addClass('ipmi-fan-context-pill--warn')
            .text(needMap + ' header' + (needMap === 1 ? '' : 's') + ' still need board.json mapping');
    } else {
        $map.removeClass('ipmi-fan-context-pill--warn').addClass('ipmi-fan-context-pill--ok')
            .text('Header mapping complete');
    }

    $('#fan-ctx-curve').text(customCurves + ' custom primary curve' + (customCurves === 1 ? '' : 's'));

    var $ov = $('#fan-ctx-override');
    if (overrides) {
        $ov.removeClass('ipmi-fan-context-pill--quiet').text(overrides + ' HDD spindown override' + (overrides === 1 ? '' : 's'));
    } else {
        $ov.addClass('ipmi-fan-context-pill--quiet').text('No HDD overrides active');
    }

    var daemon = $('#FANCONTROL').val() === 'enable';
    $('#fan-ctx-daemon').text(daemon ? 'Apply will start or keep the fan daemon' : 'Apply will stop the fan daemon if running');

    var adv = $.cookie('fanctrl_view_mode') == 'advanced';
    $('#fan-ctx-view').text(adv ? 'Editor: advanced fields visible' : 'Editor: basic summaries only');
}

function toggleFanCTRL() {
    var advanced = $.cookie('fanctrl_view_mode') == 'advanced';
    $('.fanctrl-basic').toggle(!advanced);
    $('.fanctrl-settings').each(function() {
        var controller = $(this).data('controlledBy');
        if (!advanced) {
            $(this).hide();
            return;
        }

        if (!controller) {
            $(this).show();
            return;
        }

        var control = $('[name="' + controller + '"]');
        var enabled = (!control.length || control.val() !== '0');
        $(this).toggle(enabled);
    });
    refreshFanConfiguratorBar();
}
<?php endif; ?>
</script>
