<script>
var ipmiDisplayUnitF = ('<?=htmlspecialchars($display['unit']);?>' === 'F');
var ipmiSensorFetchBusy = false;

$(function(){

    <?php if (function_exists('plugin_update_available') && $version = plugin_update_available('ipmi')): ?>
        showNotice('IPMI <?=$version?> available. <a>Update</a>','ipmi');
        $('#user-notice a').on('click', function () {
            $('#user-notice').empty();
        });
    <?php endif; ?>

    //advanced view switch set cookie and toggle advanced columns
    $('#advancedview').switchButton({
        labels_placement: 'left',
        on_label: 'Advanced View',
        off_label: 'Basic View',
        checked: ($.cookie('ipmi_sensor_mode') == 'advanced')
    })
    .change(function () {
        $('.advanced').toggle('slow');
        $.cookie('ipmi_sensor_mode', $('#advancedview')[0].checked ? 'advanced' : 'basic', { expires: 3650 });
    });

    $('#tblSensor').tablesorter({
        sortList: [[2,0]],
        sortReset: true,
        sortRestart : true,
        sortInitialOrder: 'asc',
        widgets: ['saveSort', 'filter', 'stickyHeaders'],
        widgetOptions: {
            stickyHeaders_offset: ($('#header').css("position") === "fixed") ? '90' : '0',
            stickyHeaders_attachTo: null,
            stickyHeaders_filteredToTop: true,
            filter_hideEmpty : true,
            filter_liveSearch : true,
            filter_saveFilters : true,
            filter_reset : '.reset-sensors',
            filter_functions: {
                '.filter-ip' : true,
                '.filter-type' : true,
                '.filter-reading' : {
                    'nominal'  : function(e, n, f, i, $r, c, data) {
                        return $r.find('td.reading .ipmi-reading').hasClass('ipmi-reading--nominal'); },
                    'warning'  : function(e, n, f, i, $r, c, data) {
                        return $r.find('td.reading .ipmi-reading').hasClass('ipmi-reading--warn'); },
                    'critical' : function(e, n, f, i, $r, c, data) {
                        return $r.find('td.reading .ipmi-reading').hasClass('ipmi-reading--critical'); }
                }
            }
        }
    });

    // add network class to ip address filter row cells
    $('#tblSensor tr.tablesorter-filter-row').children('td:nth-child(2)').addClass('network');

    // add advanced class to select tablesorter filter row cells
    var tdAdv = [3, 5, 6, 7, 10, 11, 12];
    $.each(tdAdv , function (index, value) {
        $('#tblSensor tr.tablesorter-filter-row').children('td:nth-child('+value+')').addClass('advanced');
    });

    sensorArray(false);
    IpmiMonitor.startIntervalWhenVisible(20000, function() {
        sensorArray(true);
    });

});

/* load ipmi sensor table */
function sensorArray(Refresh){
    if (ipmiSensorFetchBusy)
        return;
    ipmiSensorFetchBusy = true;
    ipmiPost('/plugins/ipmi/include/ipmi_helpers.php', {action:'ipmisensors'}, function(data) {
        ipmiSensorFetchBusy = false;
        var unitF = ipmiDisplayUnitF;
        if (Refresh) {
            $.each(data.Sensors, function (i, sensor) {
                $('#'+i+' td.reading').html(IpmiMonitor.readingMarkup(sensor, unitF));
            });
            return;
        }
        var rows = [];
        $.each(data.Sensors, function (i, sensor) {
            var Host = (typeof sensor.IP === 'undefined') ? '' : sensor.IP;
            var rm = IpmiMonitor.readingMarkup(sensor, unitF);
            rows.push('<tr id="'+i+'">'+
                '<td title="'+sensor.State+'"><i class="fa fa-circle orb '+ data.State[sensor.State] +'-orb middle"></i></td>'+
                '<td class="network">' +Host+'</td>'+
                '<td class="advanced">'+ sensor.ID      +'</td>'+
                '<td>'+sensor.Name+'</td>'+
                '<td class="advanced">'+ sensor.LowerNR +'</td>'+
                '<td class="advanced">'+ sensor.LowerC  +'</td>'+
                '<td class="advanced">'+ sensor.LowerNC +'</td>'+
                '<td class="reading">' + rm + '</td>'+
                '<td>'+sensor.Type+'</td>'+
                '<td class="advanced">'+ sensor.UpperNC +'</td>'+
                '<td class="advanced">'+ sensor.UpperC  +'</td>'+
                '<td class="advanced">'+ sensor.UpperNR +'</td>'+
                '</tr>');
        });
        $('#tblSensor tbody').append(rows.join(''));

        if(data.Network)
            $('.network').show();
        else
            $('.network').hide();

        if ($('#advancedview')[0].checked)
            $('.advanced').show();
        else
            $('.advanced').hide();

        var lastSearch = $('#tblSensor')[0].config.lastSearch;
        $('#tblSensor').trigger('update');
        $('#tblSensor').trigger('search', [lastSearch]);
    }, function() {
        ipmiSensorFetchBusy = false;
    });
}

</script>
