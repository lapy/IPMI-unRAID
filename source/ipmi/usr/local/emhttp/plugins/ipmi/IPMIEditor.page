<script>
$(function(){
    //autoload switch
    $('#autoload-switch').switchButton({
        labels_placement: 'left',
        on_label: 'Load Config @ unRAID Start',
        off_label: 'Load Config @ unRAID Start',
        checked: ("<?=$loadcfg;?>" == 'enable')
    })
    .change(function () {
        setAutoLoad();
        $.post('/update.php', $('#autoload-form').serializeArray());
    });

    setAutoLoad();

    $('#btnCancel').click(function() {
        $.cookie('one', 'tab1', { expires:null, path: '/'});
        location = '/Settings/IPMI';
    });

    $('#editfile').on('change', function () {
        var Config = $('#editfile')[0].selectedIndex -1;

        if (Config == 1)
            $('#load-switch').show();
        else
            $('#load-switch').hide();

        $('#ipmi-editor-json-msg').text('');
        if (Config >= 0) {
            $('#ipmi-editor-extras').prop('hidden', false);
        } else {
            $('#ipmi-editor-extras').prop('hidden', true);
        }

        if (Config === 2) {
            $('#ipmi-editor-validate-json').prop('hidden', false);
            $('#ipmi-editor-board-tools').prop('hidden', false);
            loadBoardJsonBackups();
        } else {
            $('#ipmi-editor-validate-json').prop('hidden', true);
            $('#ipmi-editor-board-tools').prop('hidden', true);
        }

        if (Config != -1){
            $('#ipmiconfig').val(Config);
            ipmiPost('/plugins/ipmi/include/ipmi_config.php', {ipmicfg:null, config:Config}, function (data) {
                    editor.setValue(data.config || '');
                }
            );
        }else{
            editor.setValue('');
        }
    });

    $('#ipmi-editor-download').on('click', function () {
        var idx = $('#editfile')[0].selectedIndex;
        var names = ['ipmi-config.txt', 'ipmi-sensors-config.txt', 'board.json'];
        var name = (idx >= 1 && idx <= 3) ? names[idx - 1] : 'ipmi-export.txt';
        var blob = new Blob([editor.getValue()], { type: 'text/plain;charset=utf-8' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = name;
        a.click();
        URL.revokeObjectURL(a.href);
        ipmiFlashBanner('Download started for ' + name + '.', 'success');
    });

    $('#ipmi-editor-validate-json').on('click', function () {
        $('#ipmi-editor-json-msg').text('');
        try {
            JSON.parse(editor.getValue());
            $('#ipmi-editor-json-msg').text('JSON is valid.');
            ipmiFlashBanner('JSON parses successfully.', 'success');
        } catch (err) {
            $('#ipmi-editor-json-msg').text(err.message || 'Invalid JSON');
            ipmiFlashBanner('JSON validation failed.', 'error');
        }
    });

    $('#ipmi-board-restore').on('click', function () {
        var name = $('#ipmi-board-backup-select').val();
        if (!name) {
            ipmiFlashBanner('No backup selected.', 'error');
            return;
        }
        ipmiPost('/plugins/ipmi/include/ipmi_plugin_tools.php', { tool: 'board_backup_restore', backup: name }, function() {
            $('#editfile').trigger('change');
            ipmiFlashBanner('Restored ' + name + '. Reloaded editor buffer.', 'success');
        }, null, { button: document.getElementById('ipmi-board-restore'), showSuccessBanner: false });
    });

    var editor = CodeMirror.fromTextArea($('#editcfg')[0], {
        theme: '<?=($display["theme"] == 'white' || $display["theme"] == 'azure') ? "default" : "dracula";?>',
        mode: 'properties',
        lineNumbers: true,
        gutters: ['CodeMirror-linenumbers'],
        extraKeys: {
            'Ctrl-Space': 'autocomplete'
        },
        hintOptions: {}
    });

    $('#tab3').click(function () {
        editor.refresh();
    });

    // save config and commit to bmc
    $('#btnSubmit').click(function () {
        editor.save();
        commitConfig();
    });

    // revert saved config file to bmc stored config
    $('#btnRevert').click(revertConfig);
});


function loadBoardJsonBackups() {
    ipmiPost('/plugins/ipmi/include/ipmi_plugin_tools.php', { tool: 'board_backup_list' }, function(data) {
        var sel = $('#ipmi-board-backup-select');
        sel.empty();
        var files = data.files || [];
        if (!files.length) {
            sel.append($('<option>').val('').text('No backups found'));
            return;
        }
        files.forEach(function(f) {
            sel.append($('<option>').val(f).text(f));
        });
    });
}

function commitConfig() {
    var Config = $('#editfile')[0].selectedIndex -1;
    if (Config != -1){
        if (Config === 2) {
            try {
                JSON.parse(editor.getValue());
            } catch (err) {
                ipmiFlashBanner('Fix JSON before saving: ' + (err.message || 'parse error'), 'error');
                return;
            }
        }
        $('#ipmiconfig').val(Config);
        ipmiPost('/plugins/ipmi/include/ipmi_config.php', $('#cfgform').serializeArray(),function (data, response) {
            swal({title:'IPMI Sensors Configuration',text:response.message || 'saved',type:'success',closeOnConfirm: true,},function() {
                location = '/Settings/IPMI';
            });
        }, function(response) {
            swal({title:'IPMI Sensors Configuration',text:ipmiResponseText(response),type:'error'});
        }, { button: document.getElementById('btnSubmit') });
    }
}

function revertConfig() {
    var Config = $('#editfile')[0].selectedIndex -1;
    if (Config != -1){
        ipmiPost('/plugins/ipmi/include/ipmi_config.php', {ipmicfg:null, config:Config}, function (data, response) {
            swal({title:'IPMI Sensors Configuration',text:response.message || 'reloaded from bmc',type:'success',closeOnConfirm: true,},function() {
                location.reload(true);
            });
        }, function(response) {
            swal({title:'IPMI Sensors Configuration',text:ipmiResponseText(response),type:'error'});
        });
    }
}

function setAutoLoad() {
    if ($('#autoload-switch')[0].checked) {
        $('#autoload').val('enable');
    }else{
        $('#autoload').val('disable');
    }
}

</script>
