#!/usr/bin/php
<?php
##############################
######  DEAMON SECTION  ######
##############################
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_runtime.php';
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_options.php';
require_once '/usr/local/emhttp/plugins/ipmi/include/ipmi_settings_fan.php';
$debug = FALSE;

set_time_limit(0);
$prog     = pathinfo(__FILE__, PATHINFO_FILENAME);
$prog2    = "ipmifan";
$lockfile = "/var/run/${prog2}.pid";
$log      = "/var/log/${prog2}";

$usage = <<<EOF

Check ASRock IPMI fan locations using ipmi-raw command and
create a json array for ipmifan script.

Usage: $prog [options]

  -f, --force      force start
      --debug      turn on debugging
      --help       display this help and exit
      --version    output version information and exit


EOF;

$shortopts = 'f';
$longopts = [
    'debug',
    'force',
    'help',
    'version'
];
$args = getopt($shortopts, $longopts);

if (array_key_exists('help', $args)) {
    echo $usage.PHP_EOL;
    exit(0);
}

if (array_key_exists('version', $args)) {
    echo 'IPMI 2 JSON: 1.0'.PHP_EOL;
    exit(0);
}

$debug  = (array_key_exists('debug', $args));
$force  = (array_key_exists('f', $args) || array_key_exists('force', $args));

if (ipmi_is_service_running($lockfile) && !$force) {
    $lock_pid = ipmi_read_pidfile($lockfile);
    fanlog("Please stop ${prog2} [$lock_pid] then try again");
    exit(0);
}

if (!array_key_exists($board, $boards)){
    $msg = "Your $board motherboard is not supported yet";
    echo $msg.PHP_EOL;
    exit(1);
}

##############################
###### FUNCTION SECTION ######
##############################

/* logfile */
function fanlog($msg) {
    global $log;

    echo PHP_EOL.$msg.PHP_EOL;

    $msg = date('Y-m-d H:i:s').' '.$msg.PHP_EOL;
    file_put_contents($log,$msg,FILE_APPEND);
}

/* debug */
function debug($m){
  global $prog, $debug;
  if($debug){
    $STDERR = fopen('php://stderr', 'w+');
    fwrite($STDERR, $m.PHP_EOL);
    fclose($STDERR);
  }
}

function ipmi2json_log_command_result($result) {
    global $debug;

    if ($debug)
        fanlog($result['command']);

    if (!$result['success'] && trim((string)$result['text']) !== '')
        fanlog(trim((string)$result['text']));
}

function ipmi2json_run_raw($raw, $payload='') {
    global $fanopt_args;

    $args = array_merge(
        ipmi_hex_tokens($raw),
        ipmi_hex_tokens($payload),
        $fanopt_args
    );

    $result = ipmi_run_process('ipmi-raw', $args);
    ipmi2json_log_command_result($result);
    return $result;
}

function payload_tokens($payload) {
    $payload = ipmi_normalize_hex_string($payload);
    return empty($payload) ? [] : explode(' ', $payload);
}

function payload_string($payload) {
    return implode(' ', $payload);
}

function asrock_probe_layout($profile_name, $cmd_count, $command_index) {
    if ($profile_name === 'asrockrack_romed8u_2t') {
        $profile = ipmi_get_asrock_fan_profile($profile_name);
        return [
            'raw' => $profile['raw'],
            'auto' => ipmi_compose_prefixed_command($profile['auto_prefix'], $profile['auto_payload']),
            'full' => ipmi_compose_prefixed_command($profile['full_prefix'], $profile['full_payload']),
            'full_prefix' => $profile['full_prefix'],
            'full_payload' => $profile['full_payload'],
            'slot_indices' => isset($profile['probe_slots']) ? $profile['probe_slots'] : range(0, $profile['slot_count'] - 1),
            'location_offset' => 1,
        ];
    }

    if ($cmd_count == 0) {
        return [
            'raw' => '00 3a 01',
            'auto' => '00 00 00 00 00 00 00 00',
            'full' => '64 64 64 64 64 64 64 64',
            'slot_start' => 0,
            'slot_end' => 7,
            'location_offset' => 1,
        ];
    }

    if ($command_index == 0) {
        return [
            'raw' => '00 3a 01',
            'auto' => '00 00 00 00 00 00',
            'full' => '01 64 64 64 64 64',
            'slot_start' => 1,
            'slot_end' => 5,
            'location_offset' => 0,
        ];
    }

    return [
        'raw' => "00 3a ${command_index}1",
        'auto' => '00 00 00 00',
        'full' => '01 64 64 64',
        'slot_start' => 1,
        'slot_end' => 3,
        'location_offset' => 0,
    ];
}

function asrock_probe_payload($full_payload, $slot_index, $probe_value='21') {
    $payload = payload_tokens($full_payload);
    if (array_key_exists($slot_index, $payload))
        $payload[$slot_index] = $probe_value;

    return payload_string($payload);
}

function asrock_profile_command($profile_name, $command_key) {
    $profile = ipmi_get_asrock_fan_profile($profile_name);
    $prefix_key = $command_key.'_prefix';
    $payload_key = $command_key.'_payload';

    if (empty($profile['raw']) || empty($profile[$prefix_key]) || empty($profile[$payload_key]))
        return [];

    return [
        'raw' => $profile['raw'],
        'payload' => ipmi_compose_prefixed_command($profile[$prefix_key], $profile[$payload_key]),
    ];
}

/* get fan sensors */
function ipmi_sensors_fans() {
    global $ipmi, $fanopt_args;

    // return empty array if no ipmi detected or network options
    if(!$ipmi && empty($fanopt_args))
        return [];

    $result = ipmi_run_process(
        '/usr/sbin/ipmi-sensors',
        array_merge(['--comma-separated-output', '--no-header-output'], $fanopt_args),
        false
    );
    $output = $result['output'];
    $return_var = $result['exit_code'];

    // return empty array if error
    if($return_var)
        return [];

    // key names for ipmi sensors output
    $keys = ['ID', 'Name', 'Type', 'Reading', 'Units', 'Event'];
    $sensors = [];

    foreach($output as $line){

    /// add sensor keys as keys to ipmi sensor output
        $sensor_raw = explode(",", $line);
        $size_raw = sizeof($sensor_raw);
        $sensor = ($size_raw < 6) ? []: array_combine($keys, array_slice($sensor_raw,0,6,true));

        if ($sensor['Type'] == 'Fan')
            $sensors[$sensor['ID']] = $sensor;
    }
    return $sensors; // sensor readings
    unset($sensors);
}

##############################
#####  PROGRAM SECTION  ######
##############################


#############################################
# ASRock legacy                             #
# ipmi-raw 00 3a 01 00 00 00 00 00 00 00 00 #
# ipmi-raw 00 3a 01 AA BB CC DD EE FF GG HH #
# 00 = smartfan mode                        #
# 01 - 64  = 1% - 100%                      #
#############################################

#############################################
# ASRock Dual Socket
# ipmi-raw 00 3a 01 CPU_1_OVERRIDE CPU_1 REAR_1 FRONT_1 FRONT_2 FRONT_3
# ipmi-raw 00 3a 11 CPU_2_OVERRIDE CPU_2 REAR_2 FRONT_4
# ipmi-raw 00 3a 01 00 AA BB CC DD EE
# ipmi-raw 00 3a 11 00 AA BB CC
#############################################

#############################################
# ASRock Rack ROMED8U-2T                          #
# ipmi-raw 00 3a d8 <16 auto/manual positions>   #
# ipmi-raw 00 3a d6 <16 PWM positions>           #
# ipmi2json only probes the 6 physical headers   #
# PWM writes require a minimum value of 16       #
#############################################

####  DO YOUR STUFF HERE  ####

$board_profile = ipmi_resolve_asrock_fan_profile($board, $board_model, $board_json);
$board_json = [];
$board_tmp = $board;

fanlog('Checking IPMI fan Locations...');

$manual_command = asrock_profile_command($board_profile, 'manual');
if (!empty($manual_command)) {
    fanlog('Setting fans to manual before probing');
    ipmi2json_run_raw($manual_command['raw'], $manual_command['payload']);
    sleep(5);
}

for($i = 0; $i <= $cmd_count; $i++){
    $probe = asrock_probe_layout($board_profile, $cmd_count, $i);
    $fans   = [];

    // set fans to full speed and get readings
    ipmi2json_run_raw($probe['raw'], $probe['full']);

    sleep(5);
    $fans_full = ipmi_sensors_fans();

    $slot_indices = isset($probe['slot_indices']) ? $probe['slot_indices'] : range($probe['slot_start'], $probe['slot_end']);

// step through each raw command position
    foreach($slot_indices as $ii){
        $msg  = 'none';
        $location = $ii + $probe['location_offset'];
        $name = 'FAN_POS'.$location;

        // set postition in raw command to 1/3 and get readings
        $probe_payload = isset($probe['full_payload']) ? $probe['full_payload'] : $probe['full'];
        $hex = asrock_probe_payload($probe_payload, $ii);
        if (isset($probe['full_prefix']))
            $hex = trim($probe['full_prefix'].' '.$hex);

        ipmi2json_run_raw($probe['raw'], $hex);

        sleep(5);
        $fans_1third = ipmi_sensors_fans();

        // check for fan speed changes
        foreach($fans_full as $fan){
            if($fan['Reading'] != 'N/A') {
                if(($fan['Reading']-$fans_1third[$fan['ID']]['Reading']) > 300) {
                    $name = $fan['Name'];
                    $msg  = $name.' 100%: '.$fan['Reading'].' 33%: '.$fans_1third[$fan['ID']]['Reading'];
                }
            }
        }
        unset($fans_1third);
        $fan_key = ipmi_canonicalize_asrock_fan_name_for_profile($board_profile, $name);
        $fans[$fan_key] = $i.'1';
        fanlog("Location $i-".$location.': '.$msg);
    }

    ipmi2json_run_raw($probe['raw'], $probe['auto']);

    if ($i !== 0)
        $board_tmp = $board.$i;

    $board_json[$board_tmp] =
        [ 'raw'   => $probe['raw'],
          'auto'  => $probe['auto'],
          'full'  => $probe['full'],
          'fans'  => $fans
        ];

}

$board_json = ipmi_normalize_asrock_board_json($board, $board_model, $board_json);

$board_json = ipmi_normalize_board_config($board, $board_model, $board_json);

fanlog('Saving board configuration...');
if (!ipmi_save_board_config($board_json))
    fanlog('Unable to save board configuration atomically.');

/* print variable */
$defined_vars = get_defined_vars();

foreach (array("_GET","_POST","_COOKIE","_FILES","argv","argc","_SERVER") as $i)
    unset($defined_vars[$i]);

debug("\nDECLARED VARIABLES:\n".print_r($defined_vars, true));
unset($defined_vars);

######  END OF SECTION  ######
?>
